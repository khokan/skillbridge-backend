model Review {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  tutorProfileId String
  studentId     String

  rating        Int      // 1..5
  comment       String?
  createdAt     DateTime @default(now())

  // Relations
  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tutorProfile  TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  student       User         @relation("ReviewsGiven", fields: [studentId], references: [id], onDelete: Restrict)

  @@index([tutorProfileId, createdAt])
  @@index([rating])
}